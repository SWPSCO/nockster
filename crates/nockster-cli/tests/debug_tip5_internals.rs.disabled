use nockapp::noun::slab::NounSlab;
use nockvm::noun::{Atom, Cell};
/// Debug TIP5 internals - examine state at each step
use nockster_core::cheetah::test_tip5_hash_words;
use tx_types::hashing::tip5::Tip5Hasher;

#[test]
fn test_tip5_internals_simple() {
    println!("\n{}", "=".repeat(80));
    println!("TIP5 INTERNALS: Simple input [1, 2, 3]");
    println!("{}\n", "=".repeat(80));

    let input = [1u64, 2, 3];

    println!("Input: {:?}", input);
    println!("Length: {}", input.len());
    println!("Remainder: {} % 10 = {}", input.len(), input.len() % 10);
    println!("Padding needed: 10 - 3 = 7");
    println!("After padding: [1, 2, 3, 1, 0, 0, 0, 0, 0, 0]");

    // Test flat array hasher
    let hash_flat = test_tip5_hash_words(&input);
    println!("\nFlat array hash:");
    println!("  {:016x?}", hash_flat);

    // Test noun-based hasher
    let mut slab: NounSlab = NounSlab::new();
    let mut list = Atom::new(&mut slab, 0).as_noun();
    for &element in input.iter().rev() {
        let atom = Atom::new(&mut slab, element).as_noun();
        list = Cell::new(&mut slab, atom, list).as_noun();
    }
    let hash_noun = Tip5Hasher::hash_varlen(list).unwrap();
    println!("\nNoun-based hash:");
    println!("  {:016x?}", hash_noun.values);

    if hash_flat == hash_noun.values {
        println!("\n✓ Hashes MATCH!");
    } else {
        println!("\n❌ Hashes DIFFER!");

        // Show which elements differ
        for i in 0..5 {
            if hash_flat[i] != hash_noun.values[i] {
                println!(
                    "  Element {}: {:016x} vs {:016x}",
                    i, hash_flat[i], hash_noun.values[i]
                );
            }
        }
    }

    println!("\n{}", "=".repeat(80));
}

#[test]
fn test_tip5_montification() {
    println!("\n{}", "=".repeat(80));
    println!("Testing Montgomery form conversion");
    println!("{}\n", "=".repeat(80));

    // Access the montification function through the test helper
    // We'll need to add this to cheetah.rs

    println!("Testing values that should be montified:");
    let test_values = [0u64, 1, 2, 100, 1000, u64::MAX];

    for &val in &test_values {
        // We can't directly test montification from here without exposing the function
        // But we can see the pattern in the output
        let input = [val];
        let hash = test_tip5_hash_words(&input);
        println!("  Input [{}]: hash[0] = {:016x}", val, hash[0]);
    }

    println!("\n{}", "=".repeat(80));
}

#[test]
fn test_tip5_with_exactly_10_elements() {
    println!("\n{}", "=".repeat(80));
    println!("TIP5: Exactly 10 elements (one full block)");
    println!("{}\n", "=".repeat(80));

    let input = [1u64, 2, 3, 4, 5, 6, 7, 8, 9, 10];

    println!("Input: {:?}", input);
    println!("Length: {} (exactly RATE)", input.len());
    println!("This requires padding to 20 elements (2 blocks)");

    // Test flat array hasher
    let hash_flat = test_tip5_hash_words(&input);
    println!("\nFlat array hash:");
    println!("  {:016x?}", hash_flat);

    // Test noun-based hasher
    let mut slab: NounSlab = NounSlab::new();
    let mut list = Atom::new(&mut slab, 0).as_noun();
    for &element in input.iter().rev() {
        let atom = Atom::new(&mut slab, element).as_noun();
        list = Cell::new(&mut slab, atom, list).as_noun();
    }
    let hash_noun = Tip5Hasher::hash_varlen(list).unwrap();
    println!("\nNoun-based hash:");
    println!("  {:016x?}", hash_noun.values);

    if hash_flat == hash_noun.values {
        println!("\n✓ Hashes MATCH!");
    } else {
        println!("\n❌ Hashes DIFFER!");
    }

    println!("\n{}", "=".repeat(80));
}

#[test]
fn test_tip5_empty_and_single() {
    println!("\n{}", "=".repeat(80));
    println!("TIP5: Edge cases - empty and single element");
    println!("{}\n", "=".repeat(80));

    // Empty input
    let empty: [u64; 0] = [];
    let hash_flat_empty = test_tip5_hash_words(&empty);

    let mut slab: NounSlab = NounSlab::new();
    let list_empty = Atom::new(&mut slab, 0).as_noun();
    let hash_noun_empty = Tip5Hasher::hash_varlen(list_empty).unwrap();

    println!("Empty input:");
    println!("  Flat: {:016x?}", hash_flat_empty);
    println!("  Noun: {:016x?}", hash_noun_empty.values);
    println!("  Match: {}", hash_flat_empty == hash_noun_empty.values);

    // Single element
    let single = [42u64];
    let hash_flat_single = test_tip5_hash_words(&single);

    let mut slab2: NounSlab = NounSlab::new();
    let mut list_single = Atom::new(&mut slab2, 0).as_noun();
    let atom = Atom::new(&mut slab2, 42).as_noun();
    list_single = Cell::new(&mut slab2, atom, list_single).as_noun();
    let hash_noun_single = Tip5Hasher::hash_varlen(list_single).unwrap();

    println!("\nSingle element [42]:");
    println!("  Flat: {:016x?}", hash_flat_single);
    println!("  Noun: {:016x?}", hash_noun_single.values);
    println!("  Match: {}", hash_flat_single == hash_noun_single.values);

    println!("\n{}", "=".repeat(80));
}
