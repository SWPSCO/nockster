use nockapp::noun::slab::NounSlab;
use nockvm::noun::{Atom, Cell};
/// Comprehensive artifact comparison between reference and current implementation
/// Dumps all intermediate values to identify where they diverge
use siger_core::cheetah::{cheetah_pub_from_sk, schnorr_sign_digest, test_tip5_hash_words};
use siger_core::cheetah::utils::{add_mod_n, be32_atom_to_t8_le, mul_mod_n, trunc_g_order_to_be32};

#[test]
fn test_artifact_comparison() {
    println!("\n{}", "=".repeat(80));
    println!("COMPREHENSIVE ARTIFACT COMPARISON");
    println!("{}\n", "=".repeat(80));

    // Test with the known-good secret key and message
    let sk_be: [u8; 32] = [
        0x12, 0x34, 0x56, 0x78, 0x9a, 0xbc, 0xde, 0xf0, 0x11, 0x11, 0x22, 0x22, 0x33, 0x33, 0x44,
        0x44, 0x55, 0x55, 0x66, 0x66, 0x77, 0x77, 0x88, 0x88, 0x99, 0x99, 0xaa, 0xaa, 0xbb, 0xbb,
        0xcc, 0xcc,
    ];
    let message = [1u64, 2, 3, 4, 5];

    println!("INPUT:");
    println!("  sk: {:02x?}", sk_be);
    println!("  message: {:016x?}", message);
    println!();

    // Step 1: Derive public key
    let pk = cheetah_pub_from_sk(sk_be);
    println!("STEP 1: Public Key");
    println!("  pk.x: {:016x?}", pk[0]);
    println!("  pk.y: {:016x?}", pk[1]);
    println!();

    // Step 2: Build nonce transcript
    let mut nonce_transcript = [0u64; 17];
    nonce_transcript[..6].copy_from_slice(&pk[0]);
    nonce_transcript[6..12].copy_from_slice(&pk[1]);
    nonce_transcript[12..].copy_from_slice(&message);

    println!("STEP 2: Nonce Transcript (pk.x || pk.y || message)");
    for (i, &val) in nonce_transcript.iter().enumerate() {
        println!("  [{}]: {:016x}", i, val);
    }
    println!();

    // Step 3: Hash nonce transcript (current implementation)
    let nonce_digest_current = test_tip5_hash_words(&nonce_transcript);
    println!("STEP 3: Nonce Digest (TIP5 hash)");
    println!("  Current: {:016x?}", nonce_digest_current);

    // Also compute with reference jet implementation
    let mut slab: NounSlab<nockvm::noun::IndirectAtom> = NounSlab::new();
    let mut list = Atom::new(&mut slab, 0).as_noun();
    for &element in nonce_transcript.iter().rev() {
        let atom = Atom::new(&mut slab, element).as_noun();
        list = Cell::new(&mut slab, atom, list).as_noun();
    }
    let nonce_digest_ref = tx_types::hashing::tip5::Tip5Hasher::hash_varlen(list).unwrap();
    println!("  Reference: {:016x?}", nonce_digest_ref.values);

    if nonce_digest_current == nonce_digest_ref.values {
        println!("  ✓ MATCH");
    } else {
        println!("  ✗ MISMATCH!");
    }
    println!();

    // Step 4: Truncate to curve order
    let nonce_be = trunc_g_order_to_be32(nonce_digest_current);
    println!("STEP 4: Nonce (truncated to curve order)");
    println!("  nonce_be: {:02x?}", nonce_be);
    println!();

    // Step 5: Compute R = nonce × G
    let r_pt = cheetah_pub_from_sk(nonce_be);
    println!("STEP 5: R Point (nonce × G)");
    println!("  R.x: {:016x?}", r_pt[0]);
    println!("  R.y: {:016x?}", r_pt[1]);
    println!();

    // Step 6: Build challenge transcript
    let mut chal_transcript = [0u64; 29];
    chal_transcript[..6].copy_from_slice(&r_pt[0]);
    chal_transcript[6..12].copy_from_slice(&r_pt[1]);
    chal_transcript[12..18].copy_from_slice(&pk[0]);
    chal_transcript[18..24].copy_from_slice(&pk[1]);
    chal_transcript[24..].copy_from_slice(&message);

    println!("STEP 6: Challenge Transcript (R.x || R.y || pk.x || pk.y || message)");
    println!("  Length: {} elements", chal_transcript.len());
    for (i, &val) in chal_transcript.iter().enumerate() {
        if i < 6 || i >= 24 {
            println!("  [{}]: {:016x}", i, val);
        } else if i == 6 {
            println!("  ... (omitting middle elements for brevity)");
        }
    }
    println!();

    // Step 7: Hash challenge transcript (current implementation)
    let chal_digest_current = test_tip5_hash_words(&chal_transcript);
    println!("STEP 7: Challenge Digest (TIP5 hash)");
    println!("  Current: {:016x?}", chal_digest_current);

    // Also compute with reference
    let mut slab2: NounSlab<nockvm::noun::IndirectAtom> = NounSlab::new();
    let mut list2 = Atom::new(&mut slab2, 0).as_noun();
    for &element in chal_transcript.iter().rev() {
        let atom = Atom::new(&mut slab2, element).as_noun();
        list2 = Cell::new(&mut slab2, atom, list2).as_noun();
    }
    let chal_digest_ref = tx_types::hashing::tip5::Tip5Hasher::hash_varlen(list2).unwrap();
    println!("  Reference: {:016x?}", chal_digest_ref.values);

    if chal_digest_current == chal_digest_ref.values {
        println!("  ✓ MATCH");
    } else {
        println!("  ✗ MISMATCH!");
    }
    println!();

    // Step 8: Truncate challenge to curve order
    let chal_be = trunc_g_order_to_be32(chal_digest_current);
    println!("STEP 8: Challenge (truncated to curve order)");
    println!("  chal_be: {:02x?}", chal_be);
    let chal_t8 = be32_atom_to_t8_le(&chal_be);
    println!("  chal_t8: {:016x?}", chal_t8.values);
    println!();

    // Step 9: Compute signature s = nonce + (chal × sk)
    println!("STEP 9: Signature Computation");
    let chal_times_sk = mul_mod_n(&chal_be, &sk_be);
    println!("  chal × sk = {:02x?}", chal_times_sk);

    let s_be = add_mod_n(&nonce_be, &chal_times_sk);
    println!("  s = nonce + (chal × sk) = {:02x?}", s_be);

    let sig_t8 = be32_atom_to_t8_le(&s_be);
    println!("  sig_t8: {:016x?}", sig_t8.values);
    println!();

    // Step 10: Compare with full signing function
    println!("STEP 10: Full Signing Function");
    let (chal_full, sig_full) = schnorr_sign_digest(sk_be, pk, message);
    println!("  challenge: {:016x?}", chal_full.values);
    println!("  signature: {:016x?}", sig_full.values);
    println!();

    // Compare
    println!("COMPARISON:");
    if chal_t8.values == chal_full.values {
        println!("  ✓ Challenge matches!");
    } else {
        println!("  ✗ Challenge MISMATCH");
        for i in 0..8 {
            if chal_t8.values[i] != chal_full.values[i] {
                println!(
                    "    [{}]: manual={:08x}, full={:08x}",
                    i, chal_t8.values[i], chal_full.values[i]
                );
            }
        }
    }

    if sig_t8.values == sig_full.values {
        println!("  ✓ Signature matches!");
    } else {
        println!("  ✗ Signature MISMATCH");
        for i in 0..8 {
            if sig_t8.values[i] != sig_full.values[i] {
                println!(
                    "    [{}]: manual={:08x}, full={:08x}",
                    i, sig_t8.values[i], sig_full.values[i]
                );
            }
        }
    }
    println!();

    // Now test with reference signer
    println!("STEP 11: Reference Signer Comparison");
    println!("  Using tx_types::signer::schnorr_sign_digest");

    let pk_ref = tx_types::transaction_types::SchnorrPubkey {
        x: tx_types::transaction_types::F6LT { values: pk[0] },
        y: tx_types::transaction_types::F6LT { values: pk[1] },
        inf: false,
    };
    let sk_t8_tx = tx_types::transaction_types::T8 {
        values: be32_atom_to_t8_le(&sk_be).values,
    };
    let msg_hash = tx_types::transaction_types::Hash { values: message };

    let (chal_ref, sig_ref) = tx_types::signer::schnorr_sign_digest(sk_t8_tx, pk_ref, msg_hash);

    println!("  Reference challenge: {:016x?}", chal_ref.values);
    println!("  Reference signature: {:016x?}", sig_ref.values);
    println!();

    if chal_full.values == chal_ref.values {
        println!("  ✓ Challenge matches reference!");
    } else {
        println!("  ✗ Challenge differs from reference");
        for i in 0..8 {
            if chal_full.values[i] != chal_ref.values[i] {
                println!(
                    "    [{}]: current={:08x}, ref={:08x}",
                    i, chal_full.values[i], chal_ref.values[i]
                );
            }
        }
    }

    if sig_full.values == sig_ref.values {
        println!("  ✓ Signature matches reference!");
    } else {
        println!("  ✗ Signature differs from reference");
        for i in 0..8 {
            if sig_full.values[i] != sig_ref.values[i] {
                println!(
                    "    [{}]: current={:08x}, ref={:08x}",
                    i, sig_full.values[i], sig_ref.values[i]
                );
            }
        }
    }

    println!("\n{}", "=".repeat(80));

    assert!(
        chal_full.values == chal_ref.values && sig_full.values == sig_ref.values,
        "Signature must match reference implementation"
    );
}
