/// Detailed Schnorr signing comparison test
/// Shows intermediate values to help debug differences
use siger_core::cheetah::{cheetah_pub_from_sk, schnorr_sign_digest, test_tip5_hash_words};

#[test]
fn test_schnorr_detailed() {
    // Test vectors
    let sk_be: [u8; 32] = [
        0x12, 0x34, 0x56, 0x78, 0x9a, 0xbc, 0xde, 0xf0, 0x11, 0x11, 0x22, 0x22, 0x33, 0x33, 0x44,
        0x44, 0x55, 0x55, 0x66, 0x66, 0x77, 0x77, 0x88, 0x88, 0x99, 0x99, 0xaa, 0xaa, 0xbb, 0xbb,
        0xcc, 0xcc,
    ];

    let pk = cheetah_pub_from_sk(sk_be);
    let message = [1u64, 2, 3, 4, 5];

    println!("\n=== Schnorr Signing Detailed Test ===");
    println!("sk (BE): {:02x?}", sk_be);
    println!("pk.x: {:016x?}", pk[0]);
    println!("pk.y: {:016x?}", pk[1]);
    println!("message: {:016x?}", message);

    // Manually compute nonce transcript to test TIP5
    let mut nonce_transcript = [0u64; 17];
    nonce_transcript[..6].copy_from_slice(&pk[0]);
    nonce_transcript[6..12].copy_from_slice(&pk[1]);
    nonce_transcript[12..].copy_from_slice(&message);

    println!("\nNonce transcript (17 elements):");
    for (i, &val) in nonce_transcript.iter().enumerate() {
        println!("  [{}]: {:016x}", i, val);
    }

    let nonce_digest = test_tip5_hash_words(&nonce_transcript);
    println!("\nNonce digest (TIP5 output): {:016x?}", nonce_digest);

    // Also test with reference implementation
    use nockapp::noun::slab::NounSlab;
    use nockvm::noun::{Atom, Cell};
    let mut slab: NounSlab<nockvm::noun::IndirectAtom> = NounSlab::new();
    let mut list = Atom::new(&mut slab, 0).as_noun();
    for &element in nonce_transcript.iter().rev() {
        let atom = Atom::new(&mut slab, element).as_noun();
        list = Cell::new(&mut slab, atom, list).as_noun();
    }
    let ref_digest = tx_types::hashing::tip5::Tip5Hasher::hash_varlen(list).unwrap();
    println!("Reference TIP5 output:        {:016x?}", ref_digest.values);

    // Now run full signing to get the actual values
    let (challenge, signature) = schnorr_sign_digest(sk_be, pk, message);

    // Also manually compute to debug
    use siger_core::cheetah::cheetah_pub_from_sk as pk_from_sk;
    use siger_core::cheetah::utils::{add_mod_n, mul_mod_n, trunc_g_order_to_be32};

    let nonce_be_manual = trunc_g_order_to_be32(nonce_digest);
    let r_pt_manual = pk_from_sk(nonce_be_manual);

    let mut chal_transcript_manual = [0u64; 29];
    chal_transcript_manual[..6].copy_from_slice(&r_pt_manual.0);
    chal_transcript_manual[6..12].copy_from_slice(&r_pt_manual.1);
    chal_transcript_manual[12..18].copy_from_slice(&pk[0]);
    chal_transcript_manual[18..24].copy_from_slice(&pk[1]);
    chal_transcript_manual[24..].copy_from_slice(&message);

    let chal_digest_manual = test_tip5_hash_words(&chal_transcript_manual);
    let chal_be_manual = trunc_g_order_to_be32(chal_digest_manual);

    println!("\nDebug intermediate values:");
    println!("  nonce_be:  {:02x?}", nonce_be_manual);
    println!("  chal_be:   {:02x?}", chal_be_manual);
    println!("  sk_be:     {:02x?}", sk_be);

    let chal_times_sk_manual = mul_mod_n(&chal_be_manual, &sk_be);
    let s_be_manual = add_mod_n(&nonce_be_manual, &chal_times_sk_manual);

    println!("  chal×sk:   {:02x?}", chal_times_sk_manual);
    println!("  s=nonce+(chal×sk): {:02x?}", s_be_manual);

    // Convert to T8 to compare
    use siger_core::cheetah::utils::be32_atom_to_t8_le;
    let s_t8_manual = be32_atom_to_t8_le(&s_be_manual);
    println!("  s as T8:   {:016x?}", s_t8_manual.values);

    println!("\nGenerated:");
    println!("  challenge: {:016x?}", challenge.values);
    println!("  signature: {:016x?}", signature.values);

    // Expected values from reference
    let expected_challenge: [u64; 8] = [
        0x364619a6, 0x6af9178c, 0x46e47b17, 0xf8609591, 0xf4c6b69a, 0x1a511b32, 0xd7e56411,
        0x2f519cb9,
    ];

    let expected_signature: [u64; 8] = [
        0x0918903a, 0x0e94f5a7, 0x34d7585a, 0xb809abfe, 0x55753257, 0x5b73fced, 0x4ac8fd17,
        0x21b70dda,
    ];

    println!("\nExpected:");
    println!("  challenge: {:016x?}", expected_challenge);
    println!("  signature: {:016x?}", expected_signature);

    println!("\nComparison:");
    let chal_match = challenge.values == expected_challenge;
    let sig_match = signature.values == expected_signature;

    if chal_match {
        println!("  ✓ Challenge MATCHES");
    } else {
        println!("  ✗ Challenge MISMATCH:");
        for i in 0..8 {
            if challenge.values[i] != expected_challenge[i] {
                println!(
                    "    [{}]: got {:08x}, expected {:08x}",
                    i, challenge.values[i], expected_challenge[i]
                );
            }
        }
    }

    if sig_match {
        println!("  ✓ Signature MATCHES");
    } else {
        println!("  ✗ Signature MISMATCH:");
        for i in 0..8 {
            if signature.values[i] != expected_signature[i] {
                println!(
                    "    [{}]: got {:08x}, expected {:08x}",
                    i, signature.values[i], expected_signature[i]
                );
            }
        }
    }

    assert!(
        chal_match && sig_match,
        "Signature does not match expected values"
    );
}
