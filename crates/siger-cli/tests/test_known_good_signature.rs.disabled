/// Test signature generation with the actual known-good transaction
use bytes::Bytes;
use nockapp::noun::slab::NounSlab;
use noun_serde::NounDecode;
use std::fs;
use siger_core::cheetah::{cheetah_pub_from_sk, schnorr_sign_tx};
use siger_core::cheetah::bip39_to_seed;
use tx_types::RawTransaction;

#[test]
fn test_known_good_draft_signature() {
    println!("\n{}", "=".repeat(80));
    println!("TESTING WITH KNOWN-GOOD.DRAFT");
    println!("{}\n", "=".repeat(80));

    // Load the known-good.draft file
    let bytes = fs::read("../../known-good.draft").expect("Failed to read known-good.draft");
    let mut slab: NounSlab = NounSlab::new();
    let noun = slab
        .cue_into(Bytes::from(bytes))
        .expect("Failed to cue known-good.draft");

    // Try to parse - could be wallet tx, raw tx, or [raw-tx tail]
    let raw = if let Ok(tx) = tx_types::Transaction::from_noun(&noun) {
        // Wallet transaction - extract raw transaction from inputs
        let mut raw = RawTransaction {
            id: tx_types::transaction_types::Hash { values: [0; 5] },
            inputs: tx.p.clone(),
            timelock_range: tx_types::transaction_types::TimelockRange {
                min: None,
                max: None,
            },
            total_fees: tx_types::transaction_types::Coins { value: 0 },
        };
        // Compute total fees and timelock from inputs
        for (_, input) in raw.inputs.p.tap() {
            raw.total_fees.value += input.spend.fee.value;
        }
        raw.id = tx_types::hashing::tx_id::compute_tx_id(
            &raw.inputs,
            &raw.timelock_range,
            raw.total_fees,
        );
        raw
    } else if let Ok(r) = RawTransaction::from_noun(&noun) {
        r
    } else if let Ok(cell) = noun.as_cell() {
        RawTransaction::from_noun(&cell.head()).expect("Failed to parse [raw-tx tail]")
    } else {
        panic!("Unknown transaction format")
    };

    println!("Transaction ID: {}", raw.id.to_b58());
    println!("Inputs: {}", raw.inputs.p.wyt());

    // Get the first (and only) input
    let inputs_vec = raw.inputs.p.tap();
    let (name, input) = &inputs_vec[0];
    println!("\nInput name: {:?}", name);

    // Get the spend and compute its sig_hash
    let mut spend = input.spend.clone();
    spend.signature = None; // Ensure no signature when computing sig_hash

    let sig_hash = spend.sig_hash();
    println!("\nComputed sig_hash: {:016x?}", sig_hash.values);

    // Now sign with our mnemonic
    let mnemonic = "around squeeze nerve chronic trophy kiwi enroll identify depth bicycle radio gate critic child claim outer detect plug market visual stuff finish crime abuse";
    let seed = bip39_to_seed(mnemonic, "").expect("bip39");
    let (sk_be, _cc) = siger_core::cheetah::master_from_seed(&seed);
    let pk = cheetah_pub_from_sk(sk_be);

    println!("\nPublic key:");
    println!("  x: {:016x?}", pk[0]);
    println!("  y: {:016x?}", pk[1]);

    println!("\nSecret key:");
    println!("  {:02x?}", &sk_be[..16]);
    println!("  {:02x?}", &sk_be[16..]);

    // Sign the sig_hash
    let (chal_t8, sig_t8) = schnorr_sign_tx(sk_be, (pk[0], pk[1]), sig_hash.values);

    println!("\nGenerated signature:");
    println!("  Challenge T8: {:08x?}", chal_t8.values);
    println!("  Signature T8: {:08x?}", sig_t8.values);

    println!("\nExpected from nw.known-good.tx:");
    println!("  Challenge T8: [eb8c34bb, 5fbaa27d, a6ce47ae, 76e3878e, f0a7ead2, 9cfab183, d3cbd877, 1b6e2dba]");
    println!("  Signature T8: [c86abd93, db388fef, f61859ac, 9f618b3a, d6c03b14, a8e6b7a9, 2edbb490, 25049f76]");

    // Compare
    let expected_chal = [
        0xeb8c34bb, 0x5fbaa27d, 0xa6ce47ae, 0x76e3878e, 0xf0a7ead2, 0x9cfab183, 0xd3cbd877,
        0x1b6e2dba,
    ];
    let expected_sig = [
        0xc86abd93, 0xdb388fef, 0xf61859ac, 0x9f618b3a, 0xd6c03b14, 0xa8e6b7a9, 0x2edbb490,
        0x25049f76,
    ];

    println!("\n{}", "-".repeat(80));
    if chal_t8.values == expected_chal {
        println!("✓ Challenge MATCHES!");
    } else {
        println!("❌ Challenge DIFFERS!");
        for i in 0..8 {
            if chal_t8.values[i] != expected_chal[i] {
                println!(
                    "  [{}]: got {:08x}, expected {:08x}",
                    i, chal_t8.values[i], expected_chal[i]
                );
            }
        }
    }

    if sig_t8.values == expected_sig {
        println!("✓ Signature MATCHES!");
    } else {
        println!("❌ Signature DIFFERS!");
        for i in 0..8 {
            if sig_t8.values[i] != expected_sig[i] {
                println!(
                    "  [{}]: got {:08x}, expected {:08x}",
                    i, sig_t8.values[i], expected_sig[i]
                );
            }
        }
    }

    println!("{}", "=".repeat(80));
}
