{
  "productName": "Siger Wallet",
  "version": "0.1.0",
  "identifier": "com.nockchain.siger",
  "build": {
    "beforeDevCommand": "cd ../web && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "cd .. && make web",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Siger Hardware Wallet",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "transparent": false,
        "fileDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' 'unsafe-inline' 'unsafe-eval' asset: http://asset.localhost",
        "script-src": "'self' 'unsafe-inline' 'wasm-unsafe-eval'",
        "style-src": "'self" "'unsafe-inline'",
        "img-src": "'self' data: asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "worker-src": "'self' blob:",
        "font-src": "'self' data:",
        "media-src": "'self'"
      },
      "dangerousRemoteDomainIpcAccess": [],
      "dangerousDisableAssetCspModification": false,
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**"]
      },
      "freezePrototype": true,
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main application capabilities",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-open",
            "dialog:allow-open",
            "dialog:allow-save",
            "fs:allow-read",
            "fs:allow-write"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage"],
    "publisher": "Nockchain",
    "copyright": "Copyright (c) 2025",
    "category": "Finance",
    "shortDescription": "Hardware wallet for Nockchain transactions",
    "longDescription": "Secure desktop application for managing your Nockchain hardware wallet and signing transactions",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libudev-dev", "libusb-1.0-0-dev"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "useBootstrapper": true,
      "entitlements": null,
      "exceptionDomain": ""
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
